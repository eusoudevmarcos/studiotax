{
  "compilerOptions": {
    /* ✅ Alvo de compilação moderno, mas compatível */
    "target": "ES2020",

    /* ✅ Bibliotecas padrão */
    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    /* ✅ JS e TS juntos */
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,

    /* ✅ Não gera saída (Next cuida da build) */
    "noEmit": true,

    /* ✅ Importação mais compatível com CommonJS */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* ⚙️ Importante — use CommonJS */
    "module": "CommonJS",

    /* ✅ Resolução padrão do Node */
    "moduleResolution": "Node",

    /* ✅ Suporte para imports absolutos */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    /* ✅ JSX mantido para o Next.js */
    "jsx": "preserve",

    /* ✅ Compilação incremental */
    "incremental": true,

    /* ✅ Permitir JSON */
    "resolveJsonModule": true,

    /* ✅ Isolamento para evitar conflitos em builds */
    "isolatedModules": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
